{
  "name": "idaptik",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "res:build": "rescript",
    "res:clean": "rescript clean",
    "res:dev": "rescript -w",
    "build": "npm run res:build && vite build",
    "lint": "eslint .",
    "dev": "concurrently \"npm run res:dev\" \"vite\"",
    "dev:vite": "vite"
  },
  "dependencies": {
    "@esotericsoftware/spine-pixi-v8": "^4.2.74",
    "@pixi/sound": "^6.0.1",
    "@pixi/ui": "^2.2.2",
    "motion": "^12.4.7",
    "pixi.js": "^8.8.1",
    "ts-loader": "^9.5.4"
  },
  "devDependencies": {
    "@assetpack/core": "^1.4.0",
    "@eslint/js": "^9.21.0",
    "@rescript/core": "^1.6.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "prettier": "^3.5.3",
    "rescript": "^11.1.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.2.0"
  }
